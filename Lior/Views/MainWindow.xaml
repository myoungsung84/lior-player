<Window x:Class="Lior.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lior.Views"
        mc:Ignorable="d"
        Title="Lior"
        Width="1080"
        Height="720"
        MinWidth="860"
        MinHeight="560"
        Background="#111318">
    <Grid Margin="16" Background="#111318">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,16"
                Padding="24"
                Background="#1B1F27"
                BorderBrush="#2B3340"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Foreground="#F3F4F6"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Text="Lior Player" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#9CA3AF"
                               FontSize="13"
                               Text="MVVM + DI + Generic Host skeleton" />
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,24,0,0"
                        Background="#0F1218"
                        BorderBrush="#313A49"
                        BorderThickness="1"
                        CornerRadius="14">
                    <Grid>
                        <local:MpvHost x:Name="VideoHost" />

                        <Border Margin="16"
                                Padding="10,6"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Background="#AA0B0F14"
                                CornerRadius="999"
                                IsHitTestVisible="False">
                            <TextBlock Foreground="#D1D5DB"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Text="Embedded mpv surface" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Padding="18"
                Background="#171B22"
                BorderBrush="#2B3340"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <UniformGrid Columns="4" Margin="0,0,0,16">
                    <Button Margin="0,0,12,0"
                            Padding="16,10"
                            Command="{Binding OpenFileCommand}"
                            Content="파일 열기" />
                    <Button Margin="0,0,12,0"
                            Padding="16,10"
                            Command="{Binding PlayCommand}"
                            Content="재생" />
                    <Button Margin="0,0,12,0"
                            Padding="16,10"
                            Command="{Binding PauseCommand}"
                            Content="일시정지" />
                    <Button Padding="16,10"
                            Command="{Binding StopCommand}"
                            Content="정지" />
                </UniformGrid>

                <StackPanel Grid.Row="1" Margin="0,0,0,10">
                    <TextBlock Foreground="#9CA3AF"
                               FontSize="12"
                               Text="선택한 파일" />
                    <Border Margin="0,4,0,0"
                            Padding="12,10"
                            Background="#11161D"
                            BorderBrush="#2B3340"
                            BorderThickness="1"
                            CornerRadius="10">
                        <TextBlock Foreground="#F3F4F6"
                                   FontSize="13"
                                   Text="{Binding CurrentMediaPath}"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Foreground="#9CA3AF"
                                   FontSize="12"
                                   Text="상태 메시지" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="#D1D5DB"
                                   FontSize="13"
                                   Text="{Binding StatusText}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="24,0,0,0">
                        <TextBlock Foreground="#9CA3AF"
                                   FontSize="12"
                                   Text="재생 상태" />
                        <Border Margin="0,4,0,0"
                                Padding="12,6"
                                HorizontalAlignment="Right"
                                Background="#202733"
                                CornerRadius="999">
                            <TextBlock Foreground="#C7D2FE"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Text="{Binding PlaybackState}" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
